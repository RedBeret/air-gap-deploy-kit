# air-gap-deploy-kit environment variables
# Copy to .env and edit as needed. Never commit .env to version control.

# Default bundle output directory
KIT_BUNDLE_DIR=./kit-bundle

# acme-parts-cloud service URL (for kit verify)
ACME_URL=http://localhost:8000

# Ollama service URL (for kit verify)
OLLAMA_URL=http://localhost:11434

# Default Ollama model to verify
OLLAMA_MODEL=gemma:2b
